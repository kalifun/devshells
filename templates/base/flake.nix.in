{
  inputs = {
    nixpkgs.url = "github:NixOS/nixpkgs/nixpkgs-unstable";
    utils.url = "github:numtide/flake-utils";
    devshells = {
      url = "@flakeUrl@";
      inputs.nixpkgs.follows = "nixpkgs";
    };
    @extraInputs@
  };

  outputs = {
    nixpkgs,
    utils,
    devshells,
    @extraOutputArgs@
    ...
  }:
    utils.lib.eachDefaultSystem (system: let
      pkgs = import nixpkgs {
        inherit system;
        @extraPkgsOverlay@
      };
    in {
      devShells.default = pkgs.mkShell {
        inputsFrom = [
          devshells.devShells.${system}."@shell@"
        ];

        packages = with pkgs; [
          @extraPackages@
        ];

        @envBlock@

        shellHook = ''
          echo "enter custom devshells"
          @extraShellHook@
        '';
      };
    });
}
